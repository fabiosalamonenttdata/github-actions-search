{
  "{{chrome}}.manifest_version": 3,
  "{{firefox}}.manifest_version": 2,
  "version": "0.0.6",
  "{{chrome}}.host_permissions": [
    "https://github.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "{{firefox}}.permissions": [
    "https://github.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "96": "icon/96.png",
    "128": "icon/128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["src/content/index.ts"]
    }
  ]
}
